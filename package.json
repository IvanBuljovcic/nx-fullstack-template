{
	"name": "nx-fullstack-app",
	"version": "0.0.0",
	"license": "MIT",
	"description": "Production-ready Nx monorepo with NestJS, Next.js, Prisma, and PostgreSQL",
	"scripts": {
		"format": "biome format",
		"format:write": "biome format --write",
		"check": "biome check",
		"check:write": "biome check --write",
		"check:staged": "biome check --staged --no-errors-on-unmatched",
		"check:changed": "biome check --changed --since=main",
		"prepare": "husky",
		"commit": "cz"
	},
	"private": true,
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.0",
		"@nx/devkit": "22.5.2",
		"@nx/js": "22.5.2",
		"@nx/nest": "^22.5.2",
		"@nx/next": "^22.5.2",
		"@nx/node": "22.5.2",
		"@nx/playwright": "22.5.2",
		"@nx/web": "22.5.2",
		"@nx/webpack": "22.5.2",
		"@playwright/test": "^1.36.0",
		"@swc-node/register": "1.11.1",
		"@swc/cli": "~0.8.0",
		"@swc/core": "1.15.8",
		"@swc/helpers": "0.5.18",
		"@types/node": "20.19.9",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/shelljs": "^0.10.0",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"husky": "^9.1.7",
		"nx": "22.5.1",
		"prettier": "^2.6.2",
		"shelljs": "^0.10.0",
		"tslib": "^2.3.0",
		"typescript": "~5.9.2",
		"verdaccio": "^6.0.5",
		"webpack-cli": "^5.1.4"
	},
	"dependencies": {
		"@nestjs/common": "^11.0.0",
		"@nestjs/core": "^11.0.0",
		"@nestjs/platform-express": "^11.0.0",
		"axios": "^1.6.0",
		"next": "~16.0.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"reflect-metadata": "^0.1.13",
		"rxjs": "^7.8.0"
	},
	"engines": {
		"node": ">=18"
	},
	"nx": {
		"includedScripts": [
			"format",
			"format:write",
			"check",
			"check:write",
			"check:staged",
			"check:changed"
		],
		"targets": {
			"local-registry": {
				"executor": "@nx/js:verdaccio",
				"options": {
					"port": 4873,
					"config": ".verdaccio/config.yml",
					"storage": "tmp/local-registry/storage"
				}
			},
			"lint": {
				"executor": "nx:run-commands",
				"options": {
					"command": "biome check {projectRoot}"
				}
			},
			"format": {
				"executor": "nx:run-commands",
				"options": {
					"command": "biome format {projectRoot}"
				}
			}
		}
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"volta": {
		"node": "24.14.0"
	}
}
